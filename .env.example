# OpenAI API 密钥 (必填)
OPENAI_API_KEY=

# 备选：如果您使用 DeepSeek 或其他兼容 OpenAI 格式的模型，可以配置 BASE_URL
OPENAI_API_BASE=

# Tavily 搜索引擎 API 密钥 (用于后续的 Researcher，必填)
# 可以在 https://tavily.com/ 免费注册获取
TAVILY_API_KEY=

MODEL_NAME=


# --- LangSmith 可观测性 ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT="DeepInsight-Agents"
